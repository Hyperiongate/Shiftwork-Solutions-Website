<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Shiftwork Solutions LLC services: custom shift schedule design, staffing strategy, change management, workforce surveys, cost analysis, and policy development for 24/7 operations." />
  <title>Our Services — Shiftwork Solutions LLC</title>
  <link rel="canonical" href="https://shift-work.com/services/" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --navy:         #1F4E79;
      --navy-dark:    #0D1F3C;
      --mid-blue:     #85B7EB;
      --blue-pale:    #EEF3F8;
      --orange:       #E8610A;
      --green:        #1D9E75;
      --white:        #FFFFFF;
      --footer-bg:    #F4F4F4;
      --body:         #1A1A1A;
      --muted:        #666666;
      --smoke:        #F4F6F8;
      --border:       #E0E0E0;
      --border-mid:   #D0D0D0;
      --text-mid:     #444444;
      --max-content:  860px;
      --max-wide:     1140px;
      --radius:       6px;
      --radius-lg:    10px;
      --shadow:       0 2px 12px rgba(0,0,0,0.07);
      --shadow-lg:    0 6px 28px rgba(0,0,0,0.10);
    }

    html { scroll-behavior: smooth; }
    body {
      font-family: Arial, -apple-system, BlinkMacSystemFont, sans-serif;
      color: var(--body);
      line-height: 1.6;
      background: var(--white);
      -webkit-font-smoothing: antialiased;
    }
    img { max-width: 100%; display: block; }

    /* ================================================================
       NAV — White bar, thin border, navy CTA
    ================================================================ */
    .site-header {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 200;
      background: #ffffff;
      border-bottom: 1px solid var(--border);
      height: 64px;
      display: flex;
      align-items: center;
    }

    .header-inner {
      max-width: 1200px;
      width: 100%;
      margin: 0 auto;
      padding: 0 24px;
      display: flex;
      align-items: center;
    }

    .site-logo {
      font-family: Arial, sans-serif;
      font-size: 17px;
      font-weight: 700;
      color: var(--navy);
      text-decoration: none;
      white-space: nowrap;
      margin-right: 24px;
      flex-shrink: 0;
      letter-spacing: -0.2px;
    }

    .main-nav {
      display: flex;
      align-items: center;
      flex: 1;
    }

    .main-nav > ul {
      list-style: none;
      display: flex;
      align-items: center;
      gap: 0;
      flex: 1;
    }

    .main-nav > ul > li { position: relative; }

    .main-nav > ul > li > a {
      display: flex;
      align-items: center;
      gap: 4px;
      padding: 20px 13px;
      font-family: Arial, sans-serif;
      font-size: 13.5px;
      font-weight: 400;
      color: #333333;
      text-decoration: none;
      transition: color 0.2s;
      white-space: nowrap;
    }

    .main-nav > ul > li > a:hover { color: var(--navy); }
    .main-nav > ul > li > a.current-page { color: var(--navy); font-weight: 700; }

    .nav-arrow { font-size: 9px; opacity: 0.5; transition: transform 0.2s; }

    .nav-dropdown {
      position: absolute;
      top: 100%; left: 0;
      background: #ffffff;
      border: 1px solid var(--border);
      border-top: 2px solid var(--navy);
      border-radius: 0 0 6px 6px;
      box-shadow: 0 8px 24px rgba(0,0,0,0.10);
      min-width: 280px;
      max-height: 520px;
      overflow-y: auto;
      opacity: 0;
      visibility: hidden;
      transform: translateY(-4px);
      transition: opacity 0.18s, visibility 0.18s, transform 0.18s;
      padding: 8px 0;
      z-index: 300;
    }

    .main-nav > ul > li:hover > .nav-dropdown {
      opacity: 1; visibility: visible; transform: translateY(0);
    }
    .main-nav > ul > li:hover > a .nav-arrow { transform: rotate(180deg); }

    .dropdown-label {
      padding: 10px 18px 4px;
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--muted);
    }

    .nav-dropdown a {
      display: block;
      padding: 7px 18px;
      font-size: 13px;
      color: #333333;
      text-decoration: none;
      transition: background 0.15s, color 0.15s;
      line-height: 1.4;
    }
    .nav-dropdown a:hover { background: var(--blue-pale); color: var(--navy); }
    .dropdown-divider { height: 1px; background: #f0f0f0; margin: 6px 0; }

    .nav-cta { margin-left: auto; flex-shrink: 0; }
    .nav-cta a {
      display: inline-block;
      padding: 9px 20px;
      background: var(--navy);
      color: #ffffff;
      font-size: 13px;
      font-weight: 700;
      text-decoration: none;
      border-radius: 5px;
      transition: background 0.2s;
      white-space: nowrap;
    }
    .nav-cta a:hover { background: #163a5c; }

    .mobile-toggle {
      display: none;
      background: none;
      border: none;
      cursor: pointer;
      padding: 8px;
      margin-left: auto;
    }
    .mobile-toggle span {
      display: block;
      width: 22px;
      height: 2px;
      background: var(--navy);
      margin: 5px 0;
      border-radius: 2px;
      transition: transform 0.3s, opacity 0.3s;
    }

    @media (max-width: 960px) {
      .main-nav {
        display: none;
        position: absolute;
        top: 64px; left: 0; right: 0;
        background: #ffffff;
        flex-direction: column;
        padding: 16px 0 24px;
        box-shadow: 0 8px 24px rgba(0,0,0,0.12);
        border-top: 1px solid var(--border);
        max-height: calc(100vh - 64px);
        overflow-y: auto;
        align-items: stretch;
      }
      .main-nav.open { display: flex; }
      .main-nav > ul { flex-direction: column; width: 100%; }
      .main-nav > ul > li > a { padding: 12px 24px; font-size: 14px; }
      .nav-dropdown {
        position: static;
        opacity: 1; visibility: visible; transform: none;
        box-shadow: none; border: none; border-radius: 0;
        max-height: none; background: #f8f9fa;
        display: none; padding: 0; min-width: 100%;
      }
      .main-nav > ul > li.mobile-open > .nav-dropdown { display: block; }
      .nav-dropdown a { padding: 9px 36px; color: #444; }
      .dropdown-label { padding: 8px 36px 2px; }
      .nav-cta { margin: 12px 24px 0; }
      .nav-cta a { display: block; text-align: center; }
      .mobile-toggle { display: block; }
    }

    /* ================================================================
       PAGE HERO — Navy stripe (Stripe A)
    ================================================================ */
    .page-hero {
      margin-top: 64px;
      background: var(--navy);
      color: var(--white);
      padding: 48px 24px 44px;
      position: relative;
      overflow: hidden;
    }

    /* Subtle depth circles per guidelines (opacity 0.05) */
    .page-hero::before {
      content: '';
      position: absolute;
      top: -80px; right: -80px;
      width: 320px; height: 320px;
      border-radius: 50%;
      background: rgba(255,255,255,0.05);
      pointer-events: none;
    }
    .page-hero::after {
      content: '';
      position: absolute;
      bottom: -60px; left: -60px;
      width: 240px; height: 240px;
      border-radius: 50%;
      background: rgba(255,255,255,0.05);
      pointer-events: none;
    }

    .hero-inner {
      max-width: var(--max-content);
      margin: 0 auto;
      position: relative;
      z-index: 1;
    }

    .eyebrow {
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--mid-blue);
      margin-bottom: 10px;
    }

    .page-hero h1 {
      font-size: 28px;
      font-weight: 700;
      line-height: 1.2;
      color: var(--white);
      margin-bottom: 14px;
      max-width: 520px;
    }

    .page-hero .hero-sub {
      font-size: 15px;
      line-height: 1.7;
      color: rgba(255,255,255,0.78);
      max-width: 520px;
      margin-bottom: 28px;
    }

    .hero-stats {
      display: flex;
      gap: 32px;
      flex-wrap: wrap;
    }

    .hero-stat {
      background: rgba(255,255,255,0.08);
      border-radius: 8px;
      padding: 14px 22px;
      text-align: center;
      min-width: 120px;
    }

    .hero-stat-num {
      font-size: 26px;
      font-weight: 700;
      color: var(--white);
      line-height: 1;
      margin-bottom: 4px;
    }

    .hero-stat-label {
      font-size: 11px;
      color: var(--mid-blue);
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    /* ================================================================
       BREADCRUMB
    ================================================================ */
    .breadcrumb {
      background: var(--white);
      border-bottom: 1px solid var(--border);
      padding: 10px 24px;
    }

    .breadcrumb-inner {
      max-width: var(--max-content);
      margin: 0 auto;
      font-size: 11px;
      color: var(--muted);
    }

    .breadcrumb-inner a {
      color: var(--muted);
      text-decoration: none;
    }
    .breadcrumb-inner a:hover { color: var(--navy); }
    .breadcrumb-inner .sep { margin: 0 6px; }
    .breadcrumb-inner .current { color: var(--navy); }

    /* ================================================================
       SHARED SECTION STYLES
    ================================================================ */
    .section {
      padding: 56px 24px;
    }

    .section-inner {
      max-width: var(--max-content);
      margin: 0 auto;
    }

    .section-eyebrow {
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--navy);
      margin-bottom: 8px;
    }

    .section-heading {
      font-size: 22px;
      font-weight: 700;
      color: var(--body);
      margin-bottom: 14px;
      line-height: 1.25;
    }

    .section-body {
      font-size: 14px;
      line-height: 1.75;
      color: #333333;
      max-width: 680px;
    }

    .section-body p { margin-bottom: 14px; }
    .section-body p:last-child { margin-bottom: 0; }

    hr.divider {
      border: none;
      border-top: 1px solid #f0f0f0;
      margin: 40px 0;
    }

    /* ================================================================
       STRIPE B — Light grey neutral break
    ================================================================ */
    .stripe-b { background: var(--smoke); }

    /* ================================================================
       STRIPE A — Navy full-bleed
    ================================================================ */
    .stripe-a {
      background: var(--navy);
      color: var(--white);
      padding: 48px 24px;
    }

    .stripe-a .section-inner { max-width: var(--max-content); }

    .stripe-a .section-eyebrow { color: var(--mid-blue); }
    .stripe-a .section-heading { color: var(--white); font-size: 22px; }
    .stripe-a .section-body { color: rgba(255,255,255,0.75); max-width: 100%; }

    /* ================================================================
       CORE SERVICES — 3-col cards
    ================================================================ */
    .services-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      margin-top: 32px;
    }

    .service-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-top: 3px solid var(--navy);
      border-radius: var(--radius-lg);
      padding: 28px 22px;
      transition: box-shadow 0.2s;
    }

    .service-card:hover { box-shadow: var(--shadow-lg); }

    .service-card h3 {
      font-size: 15px;
      font-weight: 700;
      color: var(--navy);
      margin-bottom: 10px;
      line-height: 1.3;
    }

    .service-card p {
      font-size: 13px;
      color: var(--text-mid);
      line-height: 1.65;
      margin-bottom: 10px;
    }

    .service-card .service-note {
      font-size: 12px;
      color: var(--muted);
      font-style: italic;
    }

    @media (max-width: 760px) {
      .services-grid { grid-template-columns: 1fr; }
    }
    @media (min-width: 560px) and (max-width: 760px) {
      .services-grid { grid-template-columns: repeat(2, 1fr); }
    }

    /* ================================================================
       CHALLENGES — Dark stripe, 3-col grid
    ================================================================ */
    .challenges-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      margin-top: 28px;
    }

    .challenge-card {
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.10);
      border-radius: var(--radius);
      padding: 20px 18px;
      transition: background 0.2s;
    }

    .challenge-card:hover { background: rgba(255,255,255,0.10); }

    .challenge-card h3 {
      font-size: 13px;
      font-weight: 700;
      color: var(--white);
      margin-bottom: 6px;
    }

    .challenge-card p {
      font-size: 12px;
      color: rgba(255,255,255,0.62);
      line-height: 1.55;
    }

    @media (max-width: 760px) { .challenges-grid { grid-template-columns: 1fr; } }
    @media (min-width: 520px) and (max-width: 760px) {
      .challenges-grid { grid-template-columns: repeat(2, 1fr); }
    }

    /* ================================================================
       PULL QUOTE — Option 5 (2px orange left bar, white bg, no fill)
    ================================================================ */
    .pull-quote {
      border-left: 2px solid var(--orange);
      padding: 14px 0 14px 18px;
      background: var(--white);
      margin: 36px 0;
      max-width: var(--max-content);
    }

    .pull-quote .pq-label {
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--orange);
      margin-bottom: 6px;
    }

    .pull-quote blockquote {
      font-size: 15px;
      font-style: italic;
      color: var(--body);
      line-height: 1.6;
    }

    /* ================================================================
       3-COLUMN INSIGHT CARDS
    ================================================================ */
    .three-col {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      margin-top: 28px;
    }

    .insight-card {
      background: var(--white);
      border-radius: var(--radius);
      border: 1px solid var(--border);
      padding: 22px 18px;
    }

    .insight-card.navy-top  { border-top: 3px solid var(--navy); }
    .insight-card.orange-top { border-top: 3px solid var(--orange); }
    .insight-card.green-top  { border-top: 3px solid var(--green); }

    .insight-card .ic-num {
      font-size: 28px;
      font-weight: 700;
      color: var(--navy);
      line-height: 1;
      margin-bottom: 6px;
    }

    .insight-card .ic-label {
      font-size: 13px;
      font-weight: 700;
      color: var(--body);
      margin-bottom: 8px;
    }

    .insight-card .ic-body {
      font-size: 12px;
      color: var(--text-mid);
      line-height: 1.6;
    }

    @media (max-width: 680px) { .three-col { grid-template-columns: 1fr; } }

    /* ================================================================
       ENGAGEMENT TIERS
    ================================================================ */
    .tiers-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      margin-top: 28px;
    }

    .tier-card {
      background: var(--white);
      border: 2px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 28px 22px;
      display: flex;
      flex-direction: column;
      transition: border-color 0.2s;
    }

    .tier-card:hover { border-color: var(--navy); }

    .tier-card.featured {
      border-color: var(--navy);
      background: var(--blue-pale);
    }

    .tier-badge {
      display: inline-block;
      background: var(--navy);
      color: var(--white);
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      padding: 3px 12px;
      border-radius: 20px;
      margin-bottom: 14px;
      width: fit-content;
    }

    .tier-card h3 {
      font-size: 15px;
      font-weight: 700;
      color: var(--navy);
      margin-bottom: 4px;
      line-height: 1.3;
    }

    .tier-size {
      font-size: 12px;
      color: var(--muted);
      margin-bottom: 12px;
    }

    .tier-card p {
      font-size: 13px;
      color: var(--text-mid);
      line-height: 1.65;
      margin-bottom: 16px;
    }

    .tier-includes {
      list-style: none;
      margin-bottom: 24px;
      flex: 1;
    }

    .tier-includes li {
      font-size: 13px;
      color: var(--body);
      padding: 6px 0 6px 20px;
      position: relative;
      border-bottom: 1px solid var(--border);
      line-height: 1.4;
    }

    .tier-includes li:last-child { border-bottom: none; }

    .tier-includes li::before {
      content: '✓';
      position: absolute;
      left: 0;
      color: var(--navy);
      font-weight: 700;
      font-size: 12px;
    }

    .tier-card .btn-cta {
      display: block;
      padding: 11px 18px;
      background: var(--navy);
      color: var(--white);
      font-size: 13px;
      font-weight: 700;
      text-decoration: none;
      border-radius: 5px;
      text-align: center;
      transition: background 0.2s;
    }

    .tier-card .btn-cta:hover { background: #163a5c; }

    @media (max-width: 760px) {
      .tiers-grid { grid-template-columns: 1fr; max-width: 480px; }
    }

    /* ================================================================
       PROCESS TIMELINE
    ================================================================ */
    .process-timeline {
      margin-top: 32px;
      position: relative;
      padding-left: 44px;
    }

    .process-timeline::before {
      content: '';
      position: absolute;
      left: 14px; top: 0; bottom: 0;
      width: 2px;
      background: var(--border-mid);
    }

    .process-week {
      position: relative;
      margin-bottom: 28px;
      padding-left: 20px;
    }

    .process-week:last-child { margin-bottom: 0; }

    .process-dot {
      position: absolute;
      left: -36px;
      top: 2px;
      width: 26px;
      height: 26px;
      border-radius: 50%;
      background: var(--navy);
      color: var(--white);
      font-size: 10px;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .process-week-label {
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--navy);
      margin-bottom: 2px;
    }

    .process-week h3 {
      font-size: 14px;
      font-weight: 700;
      color: var(--body);
      margin-bottom: 4px;
    }

    .process-week p {
      font-size: 13px;
      color: var(--text-mid);
      line-height: 1.65;
    }

    /* ================================================================
       CTA SECTION (Section K)
    ================================================================ */
    .cta-section {
      padding: 48px 24px;
    }

    .cta-section-inner {
      max-width: var(--max-content);
      margin: 0 auto;
    }

    .cta-block {
      background: var(--navy);
      border-radius: var(--radius-lg);
      padding: 40px 36px;
      text-align: center;
    }

    .cta-block h2 {
      font-size: 20px;
      font-weight: 700;
      color: var(--white);
      margin-bottom: 10px;
      line-height: 1.3;
    }

    .cta-block p {
      font-size: 14px;
      color: #B5D4F4;
      max-width: 520px;
      margin: 0 auto 24px;
      line-height: 1.65;
    }

    .cta-buttons {
      display: flex;
      gap: 14px;
      justify-content: center;
      flex-wrap: wrap;
    }

    .btn-white {
      display: inline-block;
      padding: 12px 24px;
      background: var(--white);
      color: var(--navy);
      font-size: 13px;
      font-weight: 700;
      text-decoration: none;
      border-radius: 5px;
      transition: background 0.2s;
    }
    .btn-white:hover { background: #e8ecf0; }

    .btn-text-link {
      display: inline-flex;
      align-items: center;
      padding: 12px 18px;
      color: #B5D4F4;
      font-size: 13px;
      font-weight: 600;
      text-decoration: none;
      transition: color 0.2s;
    }
    .btn-text-link:hover { color: var(--white); }

    /* ================================================================
       FOOTER — Light grey
    ================================================================ */
    .site-footer {
      background: var(--footer-bg);
      color: #444444;
      padding: 48px clamp(20px, 4vw, 40px) 28px;
      border-top: 1px solid #e0e0e0;
    }

    .footer-inner { max-width: 1140px; margin: 0 auto; }

    .footer-grid {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: 40px;
      margin-bottom: 36px;
    }

    .footer-col-brand .footer-logo {
      font-size: 15px;
      font-weight: 700;
      color: var(--navy);
      margin-bottom: 10px;
    }

    .footer-col-brand p {
      font-size: 13px;
      line-height: 1.65;
      color: #555555;
